{
  "functions": {
    "src/app/api/saju/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/compatibility/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
